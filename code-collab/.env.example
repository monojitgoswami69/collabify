# REST + WebSocket endpoints
#
# Local dev defaults assume:
#   - Next.js (this app)            on http://localhost:3000
#   - Socket provider (Yjs/ws)      on ws://localhost:4000
#
# In production, set the socket URL to your deployed socket-provider host.

NEXT_PUBLIC_COLLAB_URL=ws://localhost:4000

# GitHub OAuth (server-side)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_SCOPES=repo read:org read:user

# Origin of this app — used to build the OAuth redirect_uri.
# Set in production, e.g. https://codalyzer.example.com
APP_PUBLIC_URL=http://localhost:3000
