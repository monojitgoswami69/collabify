# Listen address
PORT=4000
HOST=0.0.0.0

# Set SOCKET_DEBUG=true to enable verbose per-message logging
SOCKET_DEBUG=false

# TLS / WSS — set both to enable HTTPS (and therefore WSS).
# Omit for local development (plain HTTP/WS) or when TLS is terminated
# by a reverse proxy (Nginx, Cloudflare, etc.).
# TLS_CERT=/path/to/fullchain.pem
# TLS_KEY=/path/to/privkey.pem
